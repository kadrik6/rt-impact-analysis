# ─────────────────────────────────────────────────────────────
# Supabase — get from supabase.com/dashboard/project/<id>/settings/api
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Server-side only (ingest scripts, edge functions via Supabase secrets)
# NEVER expose to frontend / VITE_ prefix
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# ─────────────────────────────────────────────────────────────
# Anthropic — get from console.anthropic.com/settings/api-keys
# Add to Supabase via: npx supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# AI budget controls (set via: npx supabase secrets set KEY=value)
#
# AI_ENABLED=false  → app töötab ilma API võtmeta (deterministlik reziim)
# AI_ENABLED=true   → "Täienda Claude AI-ga" nupp aktiveerub
# ─────────────────────────────────────────────────────────────
AI_ENABLED=false
AI_MODEL_CHEAP=claude-haiku-4-5-20251001
AI_MODEL_ANALYSIS=claude-sonnet-4-6
AI_MAX_INPUT_CHARS=12000

# ─────────────────────────────────────────────────────────────
# HuggingFace — vabatahtlik, vajalik ainult vector embedding ingest'iks
# ─────────────────────────────────────────────────────────────
HF_TOKEN=
